{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "emitDeclarationOnly": false
  }
}